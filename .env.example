# Database - Neon PostgreSQL Configuration
DATABASE_URL="postgresql://[user]:[password]@[host].neon.tech/[dbname]?sslmode=require"
# Example: postgresql://neondb_owner:npg_abc123@ep-steep-glade-a4ik5agk.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Note: We're using Neon instead of Supabase for this project
# Neon provides PostgreSQL with a generous free tier

# Authentication
NEXTAUTH_SECRET="[your-nextauth-secret]"
NEXTAUTH_URL="http://localhost:3000"

# Email Service Configuration (SMTP - Recommended for Direct Email Sending)
# Choose one of the following options:

# Option 1: Gmail (Most Common)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_SECURE="false"
EMAIL_USER="info@alfaretailers.com"
EMAIL_PASS="[your-app-specific-password]"

# Option 2: Outlook/Hotmail
# EMAIL_HOST="smtp-mail.outlook.com"
# EMAIL_PORT="587"
# EMAIL_SECURE="false"
# EMAIL_USER="info@alfaretailers.com"
# EMAIL_PASS="[your-outlook-password]"

# Option 3: Custom SMTP Provider
# EMAIL_HOST="smtp.yourprovider.com"
# EMAIL_PORT="465"
# EMAIL_SECURE="true"
# EMAIL_USER="info@alfaretailers.com"
# EMAIL_PASS="[your-smtp-password]"

# Alternative: Resend API (Third-party Service)
RESEND_API_KEY="[your-resend-api-key]"
FROM_EMAIL="leads@alfaretailers.com"
ADMIN_EMAIL="info@alfaretailers.com"

# External APIs
GOOGLE_MAPS_API_KEY="[your-google-maps-api-key]"
ZILLOW_API_KEY="[your-zillow-api-key]"

# Analytics
VERCEL_ANALYTICS_ID="[your-vercel-analytics-id]"
POSTHOG_API_KEY="[your-posthog-api-key]"

# File Upload
UPLOAD_SIZE_LIMIT="10485760" # 10MB in bytes

# Site Configuration (CRITICAL FOR SEO)
NEXT_PUBLIC_SITE_URL=https://alfaretailers.com
NEXT_PUBLIC_SITE_NAME=Alfa Retailers
NEXT_PUBLIC_SITE_DESCRIPTION=Stop losing $3,200+ monthly on vacant properties. Convert your stagnant long-term rental into a profitable short-term rental.

# Google Search Console Verification
GOOGLE_SEARCH_CONSOLE_VERIFICATION=your-google-verification-code-here
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-verification-code-here

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=your-ga-measurement-id
VERCEL_ANALYTICS_ID="[your-vercel-analytics-id]"
POSTHOG_API_KEY="[your-posthog-api-key]"

# Business Information for Structured Data
NEXT_PUBLIC_BUSINESS_PHONE=210-526-1401
NEXT_PUBLIC_BUSINESS_EMAIL=info@alfaretailers.com
BUSINESS_ADDRESS=12370 Potranco Rd, Suite 207
BUSINESS_CITY=San Antonio
BUSINESS_STATE=TX
BUSINESS_ZIP=78254
BUSINESS_COUNTRY=US
BUSINESS_LATITUDE=29.42412
BUSINESS_LONGITUDE=-98.4936

# Application Settings
NODE_ENV="development"
PORT="3000"

# Feature Flags
ENABLE_ANALYTICS="true"
ENABLE_EMAIL_NOTIFICATIONS="true"

# Contact Form Human-Only Safeguards
NEXT_PUBLIC_TURNSTILE_SITE_KEY="[your-cloudflare-turnstile-site-key]"
TURNSTILE_SECRET_KEY="[your-cloudflare-turnstile-secret-key]"
CONTACT_ALLOWED_ORIGINS="https://alfaretailers.com,https://www.alfaretailers.com,http://localhost:3000"
CONTACT_FORM_TOKEN_SECRET="[long-random-secret-for-form-token-signing]"
CONTACT_FORM_TOKEN_TTL_MS="1800000"
CONTACT_MIN_SUBMIT_MS="4000"
CONTACT_MAX_SUBMIT_MS="43200000"
CONTACT_CHALLENGE_FAIL_OPEN="false"
CONTACT_CHALLENGE_TIMEOUT_MS="4000"

# Rate limits
CONTACT_RATE_LIMIT_IP_PER_MINUTE="5"
CONTACT_RATE_LIMIT_IP_PER_HOUR="30"
CONTACT_RATE_LIMIT_IP_UA_PER_HOUR="20"
CONTACT_RATE_LIMIT_EMAIL_PER_HOUR="3"

# Bot scoring thresholds
CONTACT_BOT_SCORE_QUARANTINE_THRESHOLD="35"
CONTACT_BOT_SCORE_REJECT_THRESHOLD="55"

# Email hardening and ops
CONTACT_NOTIFICATION_RECIPIENTS="info@alfaretailers.com"
CONTACT_ALLOWED_RECIPIENT_DOMAINS="alfaretailers.com"
CONTACT_EMAIL_QUEUE_MODE="sync"
CONTACT_METRICS_ADMIN_KEY="[optional-admin-key-for-contact-metrics-endpoint]"
